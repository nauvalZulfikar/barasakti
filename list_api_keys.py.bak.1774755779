from googleapiclient.discovery import build

# If modifying these scopes, delete the file token.json.
SCOPES = ['https://www.googleapis.com/auth/cloud-platform']

def list_api_keys():
    """Shows basic usage of the API Keys API.
    Lists all API keys for a user
    """
    service = build('apikeys', 'v2', scopes=SCOPES)

    # Call the API Keys list method
    results = service.projects().locations().keys().list(
        parent='projects/[PROJECT_NUMBER]/locations/global'
    ).execute()

    items = results.get('keys', [])

    if not items:
        print('No API keys found.')
    else:
        print('API keys:')
        for item in items:
            print(u"{0} ({1})".format(item['name'], item['displayName']))

if __name__ == '__main__':
    list_api_keys()